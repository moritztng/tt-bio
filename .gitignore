# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Project outputs
boltz_results_*/
binder/
out_binder/
eval_data/
generated/
msa/
mgtbind_inputs/
tests/random_protein_sweep/
# local scratch batch for ESMFold2 runs (not repo content)
prot8/

# ...but keep the committed BoltzGen reference fixtures (the binder/ rule above would hide them)
!docs/implementation-parity-data/ref-fixtures/boltzgen/binder/
!docs/implementation-parity-data/ref-fixtures/boltzgen/binder/**

# Parity reference fixtures: externalize the large binaries (CIF structures, A3M
# MSAs) to GitHub Release assets and fetch on demand (scripts/fetch_parity_fixtures.sh).
# The small provenance JSONs/yaml/csv stay committed (they are the evidence a reader
# checks); ignore new .cif/.a3m so they are not accidentally re-added to git. The
# already-committed fixtures stay tracked (no history rewrite); this only blocks
# future binary additions.
docs/implementation-parity-data/ref-fixtures/**/*.cif
docs/implementation-parity-data/ref-fixtures/**/*.a3m

# ...but keep the vendored ESM MSA package (the msa/ rule above would hide it)
!tt_bio/_vendor/esm/utils/msa/
!tt_bio/_vendor/esm/utils/msa/*.py

# MGTBind artifacts (regenerated by mgtbind/prepare.py and evaluate.py)
mgtbind_inputs/
mgtbind/sample.csv
mgtbind/comparison.csv

# IDE
.vscode/
.idea/

# Test cache
.pytest_cache/
test_16/
*.log
memory_inputs/
oom_inputs/

.perf-runs/

# planning/status/coordination notes belong in the coworker system, not the repo
/notes/

# RFD3 port: local reference clone (not repo content)
.scratch/
